<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="LB Issue Register — Export Settings"
    Width="860" Height="700"
    MinWidth="700" MinHeight="500"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResizeWithGrip"
    Background="#F4F4F4"
    FontFamily="Founders Grotesk Regular, Arial"
    FontSize="12">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily"   Value="Founders Grotesk Medium, Arial"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="Background"   Value="#111111"/>
            <Setter Property="Padding"      Value="10,5"/>
            <Setter Property="Margin"       Value="0,10,0,4"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,0,8,0"/>
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="Foreground"        Value="#333333"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Height"                   Value="26"/>
            <Setter Property="Padding"                  Value="6,3"/>
            <Setter Property="BorderBrush"              Value="#CCCCCC"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Background"               Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize"                 Value="11"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height"          Value="32"/>
            <Setter Property="MinWidth"        Value="110"/>
            <Setter Property="Padding"         Value="14,4"/>
            <Setter Property="FontFamily"      Value="Founders Grotesk Medium, Arial"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Background"      Value="#111111"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style x:Key="CancelButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#666666"/>
        </Style>
        <Style x:Key="SmallButton" TargetType="Button">
            <Setter Property="Height"          Value="26"/>
            <Setter Property="Padding"         Value="10,2"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Background"      Value="#444444"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,0,6,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Title block -->
            <RowDefinition Height="Auto"/>   <!-- Key -->
            <RowDefinition Height="*"/>      <!-- Distribution matrix -->
            <RowDefinition Height="Auto"/>   <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════ TITLE BLOCK ═══════════════════════ -->
        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource SectionHeader}" Text="TITLE BLOCK INFORMATION"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="34"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Subject:"    Style="{StaticResource FieldLabel}"/>
                <TextBox   Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" x:Name="SubjectBox" Style="{StaticResource FieldBox}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Drawn by:"   Style="{StaticResource FieldLabel}"/>
                <TextBox   Grid.Row="1" Grid.Column="1" x:Name="DrawnByBox"   Style="{StaticResource FieldBox}"/>

                <TextBlock Grid.Row="1" Grid.Column="3" Text="Checked by:" Style="{StaticResource FieldLabel}"/>
                <TextBox   Grid.Row="1" Grid.Column="4" x:Name="CheckedByBox" Style="{StaticResource FieldBox}"/>
            </Grid>
        </StackPanel>

        <!-- ═══════════════════════ KEY ═══════════════════════════════ -->
        <StackPanel Grid.Row="1">
            <TextBlock Style="{StaticResource SectionHeader}" Text="KEY"/>
            <TextBlock Margin="0,2,0,0" FontSize="10" Foreground="#555555" TextWrapping="Wrap"
                Text="Revisions: Pxx Preliminary  |  Cxx Contractual     Distribution: E Email  |  U CDE upload  |  T Newforma  |  X Issue slip only"/>
        </StackPanel>

        <!-- ═══════════════════════ DISTRIBUTION ══════════════════════ -->
        <Grid Grid.Row="2" Margin="0,4,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Style="{StaticResource SectionHeader}"
                       Text="DISTRIBUTION — enter format code (E / U / T / X) per recipient per issue"/>

            <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" Background="White">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Grid x:Name="DistributionContainer" VerticalAlignment="Top"/>
                </ScrollViewer>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="+ Add recipient" Style="{StaticResource SmallButton}"/>
                <Button Content="− Remove last"   Style="{StaticResource SmallButton}"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════ BUTTONS ═══════════════════════════ -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel"          Style="{StaticResource CancelButton}" Margin="0,0,8,0"/>
            <Button Content="Export Register" Style="{StaticResource ActionButton}"/>
        </StackPanel>
    </Grid>
</Window>
