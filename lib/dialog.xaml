<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="LB Issue Register — Export Settings"
    Width="860" Height="950"
    MinWidth="700" MinHeight="650"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResizeWithGrip"
    Background="#F4F4F4"
    FontFamily="Founders Grotesk Regular, Arial"
    FontSize="12">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily"   Value="Founders Grotesk Medium, Arial"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="Background"   Value="#111111"/>
            <Setter Property="Padding"      Value="10,5"/>
            <Setter Property="Margin"       Value="0,10,0,4"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,0,8,0"/>
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="Foreground"        Value="#333333"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Height"                   Value="26"/>
            <Setter Property="Padding"                  Value="6,3"/>
            <Setter Property="BorderBrush"              Value="#CCCCCC"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Background"               Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize"                 Value="11"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height"          Value="32"/>
            <Setter Property="MinWidth"        Value="110"/>
            <Setter Property="Padding"         Value="14,4"/>
            <Setter Property="FontFamily"      Value="Founders Grotesk Medium, Arial"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Background"      Value="#111111"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style x:Key="CancelButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#666666"/>
        </Style>
        <Style x:Key="SmallButton" TargetType="Button">
            <Setter Property="Height"          Value="26"/>
            <Setter Property="Padding"         Value="10,2"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Background"      Value="#444444"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,0,6,0"/>
        </Style>
        <Style x:Key="MoveButton" TargetType="Button">
            <Setter Property="Height"          Value="28"/>
            <Setter Property="MinWidth"        Value="80"/>
            <Setter Property="Padding"         Value="8,2"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Background"      Value="#444444"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,0,0,6"/>
        </Style>
        <Style x:Key="ListLabel" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="#555555"/>
            <Setter Property="Margin"       Value="0,0,0,3"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Project Information -->
            <RowDefinition Height="Auto"/>   <!-- Key -->
            <RowDefinition Height="190"/>    <!-- Drawing Packages -->
            <RowDefinition Height="*"/>      <!-- Distribution matrix -->
            <RowDefinition Height="Auto"/>   <!-- Suitability -->
            <RowDefinition Height="Auto"/>   <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════ PROJECT INFORMATION ═══════════════ -->
        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource SectionHeader}" Text="PROJECT INFORMATION"/>
            <Grid Margin="0,2,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Register title"/>
                <TextBox   Grid.Column="1" x:Name="RegisterTitle"     Style="{StaticResource FieldBox}" Margin="0,0,16,0"/>
                <TextBlock Grid.Column="2" Style="{StaticResource FieldLabel}" Text="Issue date"/>
                <TextBox   Grid.Column="3" x:Name="RegisterIssueDate" Style="{StaticResource FieldBox}" Margin="0,0,16,0"/>
                <TextBlock Grid.Column="4" Style="{StaticResource FieldLabel}" Text="Revision"/>
                <TextBox   Grid.Column="5" x:Name="RegisterRevision"  Style="{StaticResource FieldBox}"/>
            </Grid>
        </StackPanel>

        <!-- ═══════════════════════ KEY ═══════════════════════════════ -->
        <StackPanel Grid.Row="1">
            <TextBlock Style="{StaticResource SectionHeader}" Text="KEY"/>
            <TextBlock Margin="0,2,0,0" FontSize="10" Foreground="#555555" TextWrapping="Wrap"
                Text="Revisions: Pxx Preliminary  |  Cxx Contractual     Distribution: E Email  |  U CDE upload  |  T Newforma  |  X Issue slip only"/>
        </StackPanel>

        <!-- ═══════════════════════ DRAWING PACKAGES ══════════════════ -->
        <Grid Grid.Row="2" Margin="0,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Style="{StaticResource SectionHeader}"
                       Text="DRAWING PACKAGES — double-click or use buttons to move between lists"/>

            <Grid Grid.Row="1" Margin="0,2,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Included list -->
                <DockPanel Grid.Column="0">
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource ListLabel}" Text="INCLUDED IN EXPORT"/>
                    <Border BorderBrush="#CCCCCC" BorderThickness="1" Background="White">
                        <ListBox x:Name="IncludedPackages" SelectionMode="Extended"
                                 BorderThickness="0" FontSize="11"/>
                    </Border>
                </DockPanel>

                <!-- Move buttons -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                    <Button x:Name="MoveToExcluded" Content="Exclude &gt;&gt;" Style="{StaticResource MoveButton}"/>
                    <Button x:Name="MoveToIncluded" Content="&lt;&lt; Include" Style="{StaticResource MoveButton}" Margin="0,0,0,0"/>
                </StackPanel>

                <!-- Excluded list -->
                <DockPanel Grid.Column="2">
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource ListLabel}" Text="EXCLUDED FROM EXPORT"/>
                    <Border BorderBrush="#CCCCCC" BorderThickness="1" Background="White">
                        <ListBox x:Name="ExcludedPackages" SelectionMode="Extended"
                                 BorderThickness="0" FontSize="11"/>
                    </Border>
                </DockPanel>
            </Grid>
        </Grid>

        <!-- ═══════════════════════ DISTRIBUTION ══════════════════════ -->
        <Grid Grid.Row="3" Margin="0,4,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Style="{StaticResource SectionHeader}"
                       Text="DISTRIBUTION — enter format code (E / U / T / X) per recipient per issue"/>

            <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" Background="White">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Grid x:Name="DistributionContainer" VerticalAlignment="Top"/>
                </ScrollViewer>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="+ Add recipient" Style="{StaticResource SmallButton}"/>
                <Button Content="− Remove selected" Style="{StaticResource SmallButton}"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════ SUITABILITY ═══════════════════════ -->
        <StackPanel Grid.Row="4">
            <Border Background="#111111" Margin="0,10,0,4" Padding="10,5">
                <CheckBox x:Name="SuitabilityEnabled" VerticalAlignment="Center">
                    <CheckBox.Content>
                        <TextBlock Text="SUITABILITY"
                                   Foreground="White"
                                   FontFamily="Founders Grotesk Medium, Arial"
                                   FontSize="11" FontWeight="SemiBold"/>
                    </CheckBox.Content>
                </CheckBox>
            </Border>
            <Border x:Name="SuitabilityPanel" Height="160"
                    BorderBrush="#CCCCCC" BorderThickness="1" Background="White"
                    Visibility="Collapsed">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <Grid x:Name="SuitabilityContainer" VerticalAlignment="Top"/>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <!-- ═══════════════════════ BUTTONS ═══════════════════════════ -->
        <StackPanel Grid.Row="5" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel"          Style="{StaticResource CancelButton}" Margin="0,0,8,0"/>
            <Button Content="Export Register" Style="{StaticResource ActionButton}"/>
        </StackPanel>
    </Grid>
</Window>
